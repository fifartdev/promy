# ─── Database ────────────────────────────────────────────────────────────────
# Copy from Neon console → Project → Connection string
DATABASE_URI=postgresql://<user>:<password>@<host>.neon.tech/<dbname>?sslmode=require

# ─── Payload ─────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
PAYLOAD_SECRET=your-32-char-secret-here

# ─── Server URL ──────────────────────────────────────────────────────────────
# Development: your machine's LAN IP (run: ipconfig getifaddr en0)
# Production:  your Vercel deployment URL (set automatically by Vercel as VERCEL_URL
#              but must be explicitly set here as NEXT_PUBLIC_ for client-side access)
NEXT_PUBLIC_SERVER_URL=http://192.168.x.x:3000
# NEXT_PUBLIC_SERVER_URL=https://promy.vercel.app   ← uncomment & set for prod

# ─── Vercel Blob Storage ─────────────────────────────────────────────────────
# Create a Blob store in Vercel Dashboard → Storage → Blob → Create
# Then copy the Read/Write token here (and add it to Vercel env vars)
# Leave empty for local dev — falls back to public/media/ directory
BLOB_READ_WRITE_TOKEN=
